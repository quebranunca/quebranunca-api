{
  "Frontend": {
    "Url": "https://app.quebranunca.com.br"
  },
  "Database": {
    "MigrateOnStartup": false,
    "ValidateOnStartup": true
  },
  "Diagnostics": {
    "EnableSwagger": false,
    "EnableDbTestEndpoint": false
  },
  "HttpsRedirection": {
    "Enabled": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "EmailConvitesCadastro": {
    "BaseUrl": "https://api.resend.com",
    "RemetenteEmail": "noreply@notificacao.quebranunca.com.br",
    "RemetenteNome": "Plataforma QuebraNunca Futevôlei",
    "ReplyTo": "contato@quebranunca.com.br",
    "UrlApp": "https://app.quebranunca.com.br"
  },
  "Jwt": {
    "Emissor": "quebranunca-api",
    "Audiencia": "quebranunca-app",
    "ExpiracaoMinutos": 720
  },
  "CodigoLoginDesenvolvimento": {
    "HabilitarFallbackSemEmail": false
  }
}
